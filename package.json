{
  "name": "buildagent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces",
    "web": "npm run dev -w apps/web",
    "api": "npm run dev -w apps/api",
    "backend:build": "tsc -p tsconfig.json",
    "backend:import-workflows": "tsx src/cli/import-workflows.ts",
    "backend:analyze-workflows": "tsx src/cli/analyze-workflows.ts",
    "backend:search-workflow": "tsx src/cli/search-workflow.ts",
    "backend:generate-workflow": "tsx src/cli/generate-workflow.ts",
    "backend:start-server": "node dist/api/server.js",
    "backend:test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@supabase/supabase-js": "^2.45.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "apps/web"
  ]
}
