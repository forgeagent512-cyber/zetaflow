    {
      "parameters": {
        "jsCode": "// Merge session_id + update_fields into a flat object for the Sheets node above\nconst input = $('Input: CRM Operation').item.json;\nreturn { json: { session_id: input.session_id, ...(input.update_fields || {}) } };"
